# ─── Kalshi (NEW API key) ────────────────────────────────────────────────────
# Create a fresh key pair at https://kalshi.com → Settings → API. Put the key id
# here and the downloaded RSA private key at the path below. NEVER commit the .pem.
KALSHI_API_KEY=REPLACE_WITH_NEW_KEY_ID
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi-private-key.pem
KALSHI_API_BASE=https://api.elections.kalshi.com

# ─── Bot ─────────────────────────────────────────────────────────────────────
# Which game config to load: config/<GAME_ID>.game.yaml + <GAME_ID>.scenarios.yaml
NBABOT_GAME_ID=NBA-2026-FINALS-G3

# Where alerts go: "stdout" or an incoming-webhook URL (Slack/Discord/Telegram)
NBABOT_DELIVER_TO=stdout

# Safety. 1 = never place orders (monitor-only, the default and intended mode).
# This bot REPORTS which game-script is becoming true; it does not chase bets.
NBABOT_DRY_RUN=1

# Where runtime state + the learning log are written
NBABOT_DATA_DIR=./data

# Conservative learned calibration overrides. Reconcile writes this; load_context reads it.
NBABOT_CALIBRATION_OVERRIDES=./data/calibration_overrides.json

# Paper is local-only. Demo uses the Kalshi demo API. Live submits real-money orders
# only when all three live gates below are set deliberately.
NBABOT_EXECUTION_MODE=paper
NBABOT_LIVE_TRADING_ACK=
NBABOT_MAX_DAILY_LOSS_UNITS=2
NBABOT_MAX_GAME_EXPOSURE_UNITS=5
NBABOT_MIN_EDGE=0.05
NBABOT_STALE_MARKET_SECONDS=90
NBABOT_MAX_SPREAD_CENTS=10
NBABOT_KILL_SWITCH=./data/KILL_SWITCH
