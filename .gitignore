# secrets — never commit
.env
secrets/*.pem
secrets/*.key
secrets/*.txt

# runtime state + learning log artifacts (keep the dir, ignore contents)
data/*.json
data/*.jsonl
data/*.sqlite
data/*.sqlite-*
!data/.gitkeep

